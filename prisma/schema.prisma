// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement()) //up number
  firstName String
  lastName String
  email String @unique
  password String
  role String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userModule User_Module[]
  userGroup User_Group[]
  contributionForms Contribution_Forms[]
}

model Module {
  id Int @id @default(autoincrement())
  name String
  groupSize Int
  groupNum Int // remove this as class size varies may need more or less groups depending on size of that year
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userModule User_Module[]
  groups Groups[]
}

model User_Module {
  userId   Int
  moduleId Int

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module   Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId]) // Composite primary key
}

model Groups {
  id Int @id @default(autoincrement())
  moduleId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  userGroup User_Group[]
  contributionForms Contribution_Forms[]
}

model User_Group {
  id Int @id @default(autoincrement())
  userId Int
  groupId Int
  hasSubmitted Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Groups @relation(fields: [groupId], references: [id], onDelete: Cascade)

  myContribution My_Contribution[]
}

model My_Contribution {
  id Int @id @default(autoincrement())
  userGroupId Int
  myUserReflection String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userGroup User_Group @relation(fields: [userGroupId], references: [id], onDelete: Cascade)

  contributionForms Contribution_Forms[]
}

model Contribution_Forms {
  id Int @id @default(autoincrement())
  contributionsId Int
  groupId Int
  targetUserId Int
  targetUserContribution Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  myContribution My_Contribution @relation(fields: [contributionsId], references: [id], onDelete: Cascade)
  group Groups @relation(fields: [groupId], references: [id], onDelete: Cascade)
  targetUser User @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
}